# TruthLens AI - Backend Configuration

# Server Settings
PORT=8000
HOST=0.0.0.0
DEBUG=True

# Application Paths
UPLOAD_DIR=app/uploads
OUTPUT_DIR=app/outputs
MODEL_DIR=app/models

# Deepfake Detection Model Config
# Options: xception, mobilenetv2
DEFAULT_MODEL_TYPE=xception
MODEL_PATH_XCEPTION=app/models/xception_deepfake_detector.h5
MODEL_PATH_MOBILENET=app/models/mobilenetv2_deepfake_detector.h5

# Preprocessing Settings
FRAME_RATE_FPS=2
MAX_FRAMES_PER_VIDEO=30
FACE_DETECTION_MIN_CONFIDENCE=0.5
IMAGE_SIZE=224

# Security / CORS
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:5173"]
